# ─── AI Providers ────────────────────────────────────────────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ─── Telegram ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, copy the token here
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGhijklmnopqrstuvwxyz

# Your Telegram chat/group/channel ID (get it via @userinfobot or @RawDataBot)
# Use a negative number for groups/channels, e.g. -1001234567890
TELEGRAM_CHAT_ID=-1001234567890

# ─── Airtable ────────────────────────────────────────────────────────────────
# Personal access token — https://airtable.com/create/tokens
# Required scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base ID — from the URL: airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ─── YouTube Channels ────────────────────────────────────────────────────────
# Comma-separated YouTube channel IDs to monitor.
# Find a channel ID at: https://www.youtube.com/channel/UC...
# Or via: https://commentpicker.com/youtube-channel-id.php
YOUTUBE_CHANNEL_IDS=UCxxxxxxxxxxxxxxxxxxxxxx,UCyyyyyyyyyyyyyyyyyyyyyy

# ─── App Settings ────────────────────────────────────────────────────────────
# How often to poll RSS feeds (minutes). Default: 10
POLL_INTERVAL_MINUTES=10

# Path to the JSON file that tracks seen video IDs. Default: seen_ids.json
SEEN_IDS_FILE=seen_ids.json

# Dashboard port. Railway sets PORT automatically; override here for local dev.
PORT=8000
